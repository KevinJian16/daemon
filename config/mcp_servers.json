      "transport": "stdio",
      "command": "python3",
      "args": ["/Users/kevinjian/daemon/mcp_servers/firecrawl_scrape.py"],
      "env": {
        "FIRECRAWL_URL": "http://127.0.0.1:3002"
      }
    },
    "github": {
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
