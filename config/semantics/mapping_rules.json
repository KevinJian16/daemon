{
  "_comment": "Semantic mapping rules — deterministic keyword/pattern matching before Cortex fallback.",
  "_version": "1.0.0",
  "_updated": "2026-03-04",
  "rules": [
    {
      "rule_id": "rule_dev_keywords",
      "priority": 10,
      "cluster_id": "clst_dev_project",
      "match": {
        "keywords": ["代码", "code", "implement", "实现", "bug", "fix", "refactor", "重构", "开发", "develop", "function", "class", "api", "接口"],
        "artifact_types": ["code", "script", "module"]
      }
    },
    {
      "rule_id": "rule_plan_keywords",
      "priority": 9,
      "cluster_id": "clst_personal_plan",
      "match": {
        "keywords": ["计划", "plan", "schedule", "日程", "安排", "goal", "目标", "roadmap", "路线图", "周计划", "月计划"],
        "artifact_types": ["plan", "schedule", "roadmap"]
      }
    },
    {
      "rule_id": "rule_synthesis_keywords",
      "priority": 8,
      "cluster_id": "clst_knowledge_synthesis",
      "match": {
        "keywords": ["整合", "synthesis", "综合", "汇总", "knowledge base", "知识库", "梳理", "整理"],
        "artifact_types": ["knowledge_base", "synthesis", "wiki"]
      }
    },
    {
      "rule_id": "rule_research_default",
      "priority": 1,
      "cluster_id": "clst_research_report",
      "match": {
        "keywords": ["研究", "research", "分析", "analyze", "报告", "report", "调研", "survey", "brief", "简报"],
        "artifact_types": ["report", "analysis", "brief"]
      },
      "is_default_fallback": true
    }
  ],
  "confidence_thresholds": {
    "high": 0.85,
    "medium": 0.60,
    "low": 0.0
  }
}
