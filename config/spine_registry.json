{
  "version": 6,
  "routines": {
    "spine.pulse": {
      "mode": "deterministic",
      "schedule": "*/10 * * * *",
      "timeout_s": 120,
      "nerve_triggers": ["service_error"],
      "reads": ["infra:health"],
      "writes": ["state:ward"],
      "depends_on": [],
      "degraded_mode": null
    },
    "spine.record": {
      "mode": "deterministic",
      "schedule": null,
      "timeout_s": 120,
      "nerve_triggers": ["deed_closed", "herald_completed"],
      "reads": ["state:trails"],
      "writes": ["psyche:ledger:dag_templates", "psyche:ledger:skill_stats", "psyche:ledger:agent_stats"],
      "depends_on": [],
      "degraded_mode": null
    },
    "spine.witness": {
      "mode": "deterministic",
      "schedule": "0 */6 * * *",
      "timeout_s": 300,
      "nerve_triggers": [],
      "reads": ["psyche:ledger:stats"],
      "writes": ["state:system_health"],
      "depends_on": ["spine.record"],
      "degraded_mode": null
    },
    "spine.focus": {
      "mode": "deterministic",
      "schedule": "0 6 * * 1",
      "timeout_s": 300,
      "nerve_triggers": [],
      "reads": ["psyche:ledger:stats", "state:deeds"],
      "writes": [],
      "depends_on": ["spine.witness"],
      "degraded_mode": null
    },
    "spine.relay": {
      "mode": "deterministic",
      "schedule": "0 */4 * * *",
      "timeout_s": 300,
      "nerve_triggers": ["config_updated"],
      "reads": ["psyche:config", "psyche:ledger"],
      "writes": ["state:snapshots"],
      "depends_on": [],
      "degraded_mode": null
    },
    "spine.tend": {
      "mode": "deterministic",
      "schedule": "0 3 * * *",
      "timeout_s": 1800,
      "nerve_triggers": ["ward_changed"],
      "reads": ["state", "psyche:config"],
      "writes": ["state", "psyche:config:rations"],
      "depends_on": [],
      "degraded_mode": null
    },
    "spine.curate": {
      "mode": "deterministic",
      "schedule": "0 2 * * 0",
      "timeout_s": 1800,
      "nerve_triggers": [],
      "reads": ["state:deeds", "state:vault"],
      "writes": ["state:vault"],
      "depends_on": [],
      "degraded_mode": null
    }
  }
}
