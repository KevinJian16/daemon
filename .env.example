# Optional override — defaults to the daemon/ directory itself. Set only if running from a different path.
# DAEMON_HOME=/Users/yourname/daemon

# LLM providers (at least one required; DeepSeek recommended as primary)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
BRAVE_API_KEY=

# Telegram (optional — for delivery notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Temporal (optional — defaults shown)
# TEMPORAL_ADDRESS=localhost:7233
# TEMPORAL_NAMESPACE=default
# TEMPORAL_TASK_QUEUE=daemon-queue
