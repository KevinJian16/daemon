# Optional override — defaults to the daemon/ directory itself. Set only if running from a different path.
# DAEMON_HOME=/Users/yourname/daemon

# ============================================================
# LLM Providers (at least one required)
# ============================================================
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
BRAVE_API_KEY=
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================================
# Telegram (4 bots — one per scene)
# ============================================================
TELEGRAM_BOT_TOKEN_COPILOT=
TELEGRAM_BOT_TOKEN_INSTRUCTOR=
TELEGRAM_BOT_TOKEN_NAVIGATOR=
TELEGRAM_BOT_TOKEN_AUTOPILOT=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_USERS=

# ============================================================
# Infrastructure (Docker Compose)
# ============================================================

# PostgreSQL (shared: daemon + Plane + Langfuse)
POSTGRES_USER=daemon
POSTGRES_PASSWORD=daemon
POSTGRES_DB=daemon

# Redis (shared: Plane + Langfuse)
# No extra config needed — defaults work

# MinIO (shared: Plane + Langfuse + daemon artifacts)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# RabbitMQ (Plane message queue)
RABBITMQ_USER=plane
RABBITMQ_PASSWORD=plane

# ClickHouse (Langfuse OLAP)
CLICKHOUSE_USER=langfuse
CLICKHOUSE_PASSWORD=langfuse

# ============================================================
# Plane
# ============================================================
PLANE_SECRET_KEY=super-secret-key-change-me
PLANE_API_URL=http://localhost:8000
PLANE_API_TOKEN=

# ============================================================
# Langfuse
# ============================================================
LANGFUSE_NEXTAUTH_SECRET=langfuse-secret-change-me
LANGFUSE_SALT=langfuse-salt-change-me
LANGFUSE_ENCRYPTION_KEY=  # 256-bit hex: openssl rand -hex 32
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=pk-lf-daemon-dev
LANGFUSE_SECRET_KEY=sk-lf-daemon-dev
LANGFUSE_INIT_EMAIL=admin@daemon.local
LANGFUSE_INIT_PASSWORD=daemon-admin

# ============================================================
# Temporal
# ============================================================
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=daemon-queue

# ============================================================
# OpenClaw Gateway
# ============================================================
OPENCLAW_GATEWAY_TOKEN=

# ============================================================
# Security
# ============================================================
DAEMON_ACCESS_TOKEN=
